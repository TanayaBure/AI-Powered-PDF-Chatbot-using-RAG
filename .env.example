# RAG Pipeline Configuration Template
# Copy this file to .env and fill in the values.

# 1. LLM Provider settings
# Options: ollama (default local), huggingface (cloud), openai (cloud), groq (cloud)
LLM_PROVIDER=ollama

# 2. API Keys (Only required if using cloud providers)
HF_TOKEN=your_huggingface_token_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# 3. Model Names (Optional)
# If using ollama: llama3.2, mistral, etc.
# If using huggingface: meta-llama/Llama-3.2-3B-Instruct
# If using openai: gpt-4o-mini
# If using groq: llama3-8b-8192
MODEL_NAME=llama3.2
